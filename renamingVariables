Solution 2: The below program is to guess the correct number between 1 to 100

def isValidNumber(guess):
    if guess.isdigit() and 1<= int(guess) <=100:
        return True
    else:
        return False

def main():
    secretNumber=random.randint(1,100)
    isCorrectGuess=False
    guess=input("Guess a number between 1 and 100:")
    guessesMade=0
    while not isCorrectGuess:
        if not isValidNumber(guess):
            guess=input("I wont count this one Please enter a number between 1 to 100")
            continue
        else:
            guessesMade+=1
            guess=int(guess)

        if guess<secretNumber:
            guess=input("Too low. Guess again")
        elif guess>secretNumber:
            guess=input("Too High. Guess again")
        else:
            print("You guessed it in",guessesMade,"guesses!")
            isCorrectGuess=True

main()


Solution 3: The below program is to check whether the number is Armstrong number or not

def generateArmstrong(userInput):
    # Initializing Sum and Number of Digits
    armstrongNumber = 0
    digitCount = 0

    # Calculating Number of individual digits
    calcNum = userInput
    while calcNum > 0:
        digitCount = digitCount + 1
        calcNum = calcNum // 10

    # Finding Armstrong Number
    calcNum = userInput
    for n in range(1, calcNum + 1):
        recentDigit = calcNum % 10
        armstrongNumber = armstrongNumber + (recentDigit ** digitCount)
        calcNum //= 10
    return armstrongNumber


# End of Function

# User Input
userInput = int(input("\nPlease Enter the Number to Check for Armstrong: "))

if (userInput == generateArmstrong(userInput)):
    print("\n %d is Armstrong Number.\n" % userInput)
else:
    print("\n %d is Not a Armstrong Number.\n" % userInput)
